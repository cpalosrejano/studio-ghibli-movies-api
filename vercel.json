{
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python"
        }
    ],
    "includeFiles": ["translations/**/*"],
    "buildCommand": "pybabel compile -f -d translations",
    "routes": [
        {
            "src": "/(.*)",
            "dest": "main.py"
        }
    ]
}
