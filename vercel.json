{
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python",
            "config": { "maxLambdaSize": "15mb" }
        }
    ],
    "buildCommand": "pybabel compile -f -d translations",
    "routes": [
        {
            "src": "/(.*)",
            "dest": "main.py"
        }
    ]
}
